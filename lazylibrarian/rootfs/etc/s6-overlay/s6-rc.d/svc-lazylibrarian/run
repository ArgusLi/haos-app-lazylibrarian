#!/usr/bin/with-contenv bash
# shellcheck shell=bash
# Overrides the linuxserver svc-lazylibrarian run script to inject --http_root
# when ingress mode is active, so LazyLibrarian loads the correct webroot at
# startup regardless of what is (or isn't) in config.ini.

if bashio::config.equals "connection_mode" "ingress"; then
    http_root_arg="--http_root=/lazylibrarian"
else
    http_root_arg=""
fi

exec \
    s6-notifyoncheck -d -n 300 -w 1000 -c "nc -z localhost 5299" \
        s6-setuidgid abc python3 /app/lazylibrarian/LazyLibrarian.py \
        --datadir /config --nolaunch ${http_root_arg}
